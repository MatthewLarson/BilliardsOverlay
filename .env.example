# Raspberry Pi sensor-node provisioning settings.
# Copy to .env (which is git-ignored) and fill in the SSH login.
#   cp .env.example .env
PI_HOST=192.168.4.127
PI_PORT=22
PI_USER=pi
PI_PASSWORD=
# The brain machine's LAN IP (this PC); the Pi streams frames here.
BRAIN_HOST=192.168.4.162
# Where to install Pool Guide on the Pi.
PI_APP_DIR=/home/PI_USER/pool_guide
# Chromecast friendly name or IP the projector is plugged into (blank = cast manually).
CHROMECAST=
